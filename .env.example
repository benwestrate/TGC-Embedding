# OpenAI API key — required for generating embeddings
OPENAI_API_KEY=sk-...

# ChromaDB collection name
CHROMA_COLLECTION=tgc_site

# ChromaDB persistence directory (relative to project root)
CHROMA_PATH=./chroma_db

# Directory containing sitemap.txt, processed.txt, failed.txt, stats.json
WORK_DIR=./crawl_state

# Word chunk size for splitting page text
CHUNK_SIZE=500

# Overlapping words between consecutive chunks
CHUNK_OVERLAP=50

# Number of URLs to process concurrently
CONCURRENCY=5

# Maximum retry attempts per URL before marking as failed
MAX_RETRIES=3

# Base delay in ms before the first retry (doubles each attempt)
RETRY_DELAY_MS=5000

# Polite delay in ms between individual page fetches
REQUEST_DELAY_MS=500

# Set to true to use a headless Chromium browser (via Playwright) for fetching.
# Required for JavaScript-rendered pages (React, Vue, Angular SPAs).
# When false (default), the faster axios HTTP fetch is used.
USE_BROWSER=false

# How long (ms) the headless browser waits for network-idle before capturing HTML.
# Increase for pages with slow async data loading. Only used when USE_BROWSER=true.
BROWSER_TIMEOUT_MS=30000
