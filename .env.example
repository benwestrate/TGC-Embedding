# OpenAI API key — required for generating embeddings
OPENAI_API_KEY=sk-...

# ChromaDB collection name
CHROMA_COLLECTION=tgc_site

# ChromaDB endpoint URL (recommended, e.g. local Docker: http://localhost:8000)
# You can also set a filesystem path, but most setups should use an HTTP URL.
CHROMA_PATH=http://localhost:8000

# Directory containing sitemap.txt, processed.txt, failed.txt, stats.json
WORK_DIR=./crawl_state

# Word chunk size for splitting page text
CHUNK_SIZE=500

# Overlapping words between consecutive chunks
CHUNK_OVERLAP=50

# Number of URLs to process concurrently
CONCURRENCY=5

# Maximum retry attempts per URL before marking as failed
MAX_RETRIES=3

# Base delay in ms before the first retry (doubles each attempt)
RETRY_DELAY_MS=5000

# Polite delay in ms between individual page fetches
REQUEST_DELAY_MS=500

# Set to true to use a headless Chromium browser (via Playwright) for fetching.
# Required for JavaScript-rendered pages (React, Vue, Angular SPAs).
# When false (default), the faster axios HTTP fetch is used.
USE_BROWSER=false

# How long (ms) the headless browser waits for network-idle before capturing HTML.
# Increase for pages with slow async data loading. Only used when USE_BROWSER=true.
BROWSER_TIMEOUT_MS=30000

# Include only URLs containing at least one of these substrings.
# Default scope: articles, podcasts, sermons, essays, and blogs.
# Set to an empty string (URL_INCLUDE=) to disable include filtering.
URL_INCLUDE=/article/,/podcasts/,/sermon/,/essay/,/blogs/

# Exclude URLs containing any of these substrings (optional).
# Example: URL_EXCLUDE=/profile/,/feed
URL_EXCLUDE=

# ── Test / dry-run flags ──────────────────────────────────────────────────────

# Set to true to run the pipeline without calling OpenAI or writing to ChromaDB.
# Pages are still fetched, extracted, and chunked — only the embed + store steps
# are skipped.  processed.txt and failed.txt are NOT updated.
# Useful for validating sitemap coverage, fetch connectivity, and extraction quality.
DRY_RUN=false

# Limit the number of pending URLs processed per run (0 = no limit).
# Combine with DRY_RUN=true for a cheap smoke-test of the first N pages.
LIMIT=0
