# Copy to deploy/proxmox/.env.production on the VM.
# Never commit real secrets.

# Required for semantic query embedding in the search API.
OPENAI_API_KEY=sk-REPLACE_ME

# Chroma collection used by the UI and embed job.
CHROMA_COLLECTION=tgc_site

# Internal service routing in docker compose.
CHROMA_PATH=http://chroma:8000

# Search API behavior.
SEARCH_TOP_K=8
SEARCH_MAX_TOP_K=20
EMBEDDING_MODEL=text-embedding-3-small

# Public URL that users visit (used only for docs/ops context).
APP_DOMAIN=search.example.com

# Container publishing controls for the VM (proxy LXC connects here).
SEARCH_UI_PORT=3000
SEARCH_UI_BIND_ADDRESS=0.0.0.0
